[importlinter]
root_packages =
    scripts

[importlinter:contract:guardrail_runtime_layers]
name = Guardrail runtime layers stay inward-facing
type = layers
containers =
    scripts
layers =
    guardrail
    guardrail_doctor | verify_quiet | check_change_budget | check_file_lengths | check_suppression_budget
    guardrail_catalog | guardrail_executor | guardrail_layout
    guardrail_config | guardrail_reporting
    guardrail_models
exhaustive = true
