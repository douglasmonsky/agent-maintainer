#!/bin/sh
set -eu
record_dir="${JAVA_RUNNER_TEST_RECORD_DIR:?}"
mkdir -p "$record_dir"
pwd > "$record_dir/cwd.txt"
printf '%s\n' "$@" > "$record_dir/argv.txt"
exit_code="${JAVA_RUNNER_TEST_EXIT_CODE:-0}"
for argument in "$@"; do
    case "$argument" in
        --*) ;;
        *)
            if [ "$exit_code" -eq 0 ]; then
                printf '> Task :%s\n' "$argument"
            else
                printf '> Task :%s FAILED\n' "$argument"
            fi
            ;;
    esac
done
exit "$exit_code"
