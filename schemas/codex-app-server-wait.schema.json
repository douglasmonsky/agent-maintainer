{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-maintainer.dev/schemas/codex-app-server-wait.schema.json",
  "title": "Codex App Server Wait Messages",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "properties": {"message": {"type": "string"}}
    },
    "id": {"type": "integer"},
    "method": {
      "enum": [
        "initialize",
        "initialized",
        "thread/read",
        "thread/resume",
        "turn.completed",
        "turn/completed",
        "turn/start"
      ]
    },
    "params": {
      "type": "object",
      "properties": {
        "clientInfo": {"type": "object"},
        "includeTurns": {"type": "boolean"},
        "input": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {"type": "string"},
              "type": {"const": "text"}
            }
          }
        },
        "threadId": {"type": "string", "minLength": 1}
      }
    },
    "result": {"type": "object"},
    "type": {"enum": ["turn.completed", "turn/completed"]}
  },
  "oneOf": [
    {"$ref": "#/$defs/initialize"},
    {"$ref": "#/$defs/initialized"},
    {"$ref": "#/$defs/threadResume"},
    {"$ref": "#/$defs/threadRead"},
    {"$ref": "#/$defs/turnStart"},
    {"$ref": "#/$defs/resultResponse"},
    {"$ref": "#/$defs/errorResponse"},
    {"$ref": "#/$defs/terminalMethod"},
    {"$ref": "#/$defs/terminalType"}
  ],
  "$defs": {
    "initialize": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"const": 1},
        "method": {"const": "initialize"},
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clientInfo": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": {"const": "agent_maintainer"},
                "title": {"const": "Agent Maintainer"},
                "version": {"type": "string", "minLength": 1}
              },
              "required": ["name", "title", "version"]
            }
          },
          "required": ["clientInfo"]
        }
      },
      "required": ["id", "method", "params"]
    },
    "initialized": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {"const": "initialized"},
        "params": {"type": "object", "additionalProperties": false}
      },
      "required": ["method", "params"]
    },
    "threadResume": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "integer"},
        "method": {"const": "thread/resume"},
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"threadId": {"type": "string", "minLength": 1}},
          "required": ["threadId"]
        }
      },
      "required": ["id", "method", "params"]
    },
    "threadRead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "integer"},
        "method": {"const": "thread/read"},
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includeTurns": {"type": "boolean"},
            "threadId": {"type": "string", "minLength": 1}
          },
          "required": ["includeTurns", "threadId"]
        }
      },
      "required": ["id", "method", "params"]
    },
    "turnStart": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "integer"},
        "method": {"const": "turn/start"},
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "input": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "text": {"type": "string"},
                  "type": {"const": "text"}
                },
                "required": ["text", "type"]
              }
            },
            "threadId": {"type": "string", "minLength": 1}
          },
          "required": ["input", "threadId"]
        }
      },
      "required": ["id", "method", "params"]
    },
    "resultResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {"id": {"type": "integer"}, "result": {"type": "object"}},
      "required": ["id", "result"]
    },
    "errorResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "error": {
          "type": "object",
          "properties": {"message": {"type": "string"}},
          "required": ["message"]
        },
        "id": {"type": "integer"}
      },
      "required": ["error", "id"]
    },
    "terminalMethod": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {"enum": ["turn.completed", "turn/completed"]},
        "params": {"type": "object"}
      },
      "required": ["method"]
    },
    "terminalType": {
      "type": "object",
      "additionalProperties": false,
      "properties": {"type": {"enum": ["turn.completed", "turn/completed"]}},
      "required": ["type"]
    }
  }
}
