{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/post_tool_use.py\"",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "async": true,
            "asyncRewake": true,
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/post_pr_wait.py\"",
            "timeout": 1800,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/stop.py\"",
            "timeout": 600,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/subagent_stop.py\"",
            "timeout": 600,
            "type": "command"
          }
        ]
      }
    ]
  }
}
